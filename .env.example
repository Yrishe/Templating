# Django
DJANGO_SECRET_KEY=your-secret-key-here-min-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (Postgres container vars)
POSTGRES_DB=contract_mgmt
POSTGRES_USER=contract_user
POSTGRES_PASSWORD=contract_pass

# Database (Django settings vars — must match the Postgres vars above)
DB_NAME=contract_mgmt
DB_USER=contract_user
DB_PASSWORD=contract_pass
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (AWS SES)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
AWS_SES_REGION_NAME=eu-west-1
DEFAULT_FROM_EMAIL=noreply@example.com

# AI (Email Organiser) — used by Phase 3 (10) Claude suggestion replies
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=claude-sonnet-4-6

# Inbound email webhook (Phase 3 (8)) — shared secret the SES/SendGrid
# webhook caller must include in the X-Webhook-Secret header.
# Generate with: openssl rand -hex 32
INBOUND_EMAIL_WEBHOOK_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Sentry (optional in dev)
SENTRY_DSN=
