# Django
DJANGO_SECRET_KEY=your-secret-key-here-min-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (Postgres container vars)
POSTGRES_DB=contract_mgmt
POSTGRES_USER=contract_user
POSTGRES_PASSWORD=contract_pass

# Database (Django settings vars — must match the Postgres vars above)
DB_NAME=contract_mgmt
DB_USER=contract_user
DB_PASSWORD=contract_pass
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email — Brevo SMTP relay (production). Dev defaults to the console backend
# via config/settings/base.py so no SMTP call leaves your laptop.
# Get the SMTP key (NOT your Brevo account password) from
# https://app.brevo.com/settings/keys/smtp.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=          # your Brevo login email
EMAIL_HOST_PASSWORD=      # your Brevo SMTP key
DEFAULT_FROM_EMAIL=noreply@example.com

# Textract OCR fallback for scanned contract PDFs (optional — leave empty
# to skip the fallback and rely on pypdf-only extraction).
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AI (Email Organiser) — used by Phase 3 (10) Claude suggestion replies
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=claude-sonnet-4-6

# Inbound email webhook (Phase 3 (8)) — shared secret the SES/SendGrid
# webhook caller must include in the X-Webhook-Secret header.
# Generate with: openssl rand -hex 32
INBOUND_EMAIL_WEBHOOK_SECRET=

# Feature flags (research Phase 1 — docs/research.md §A.1)
# Gate the 👍/👎 widget on AI classifications + suggested replies.
# Defaults off so production deploys don't light it up unintentionally.
FEATURE_AI_THUMBS=false

# Per-feature feedback widget (thumbs + comment, mountable on any feature).
# Default off; flip to true locally to light up the widgets on dashboard,
# project overview, and email-organiser analysis for manual testing.
FEATURE_FEATURE_FEEDBACK=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Build-time fallback read by useFeatureFlag when the /api/auth/me/
# response hasn't landed yet (SSR, Storybook, anonymous preview paths).
# Normal flow reads the flag from the authenticated /me response.
NEXT_PUBLIC_FEATURE_AI_THUMBS=false
NEXT_PUBLIC_FEATURE_FEATURE_FEEDBACK=false

# Sentry (optional in dev)
SENTRY_DSN=
