          <mxGeometry x="40" y="500" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ns-t8" value="manager_alert&#xa;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;Manager-scoped alert (legacy)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ns-t9" value="system&#xa;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;Platform-wide announcement (legacy)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ns-tasks-title" value="&lt;b&gt;Emission (Celery tasks in notifications/tasks.py)&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="100" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="ns-task1" value="create_contract_request_notification&#xa;(cr_pk, lifecycle=&#39;raised&#39;|&#39;approved&#39;|&#39;rejected&#39;, actor_id)&#xa;→ type = contract_request[_approved|_rejected]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="140" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ns-task2" value="create_contract_update_notification&#xa;(contract_pk, action, actor_id)&#xa;→ type = contract_update" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="210" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ns-task3" value="create_chat_message_notification&#xa;(message_pk) [actor = message.author]&#xa;→ type = chat_message" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="280" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ns-task4" value="create_incoming_email_notification&#xa;(incoming_email_pk) [actor = null — external sender]&#xa;→ type = new_email" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="350" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ns-task5" value="check_upcoming_deadlines(lookahead_days=3)&#xa;Scheduled; dedup via triggered_by_timeline_event FK&#xa;→ type = deadline_upcoming (PLANS.md §6)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="420" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ns-filter-title" value="&lt;b&gt;Feed queryset (NotificationListView)&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="510" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="ns-filter-rule" value="Notification.objects&#xa;  .filter(project__in=visible_project_ids)&#xa;  .exclude(read_by=user)&#xa;  .filter(Q(actor__isnull=True) | ~Q(actor=user))" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontFamily=monospace;align=left;" vertex="1" parent="1">
          <mxGeometry x="360" y="540" width="500" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ns-filter-note" value="• Per-user dismissal: clicking a row adds user to read_by M2M — the row disappears for that user only.&#xa;• Actor suppression: users never see notifications they themselves caused (see Django nullable-FK footgun below).&#xa;• Q-object form preserves NULL-actor rows that plain `.exclude(actor=user)` silently drops." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#fffde7;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="640" width="500" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ns-route-title" value="&lt;b&gt;Click-through routing (hrefForNotification)&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="100" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="ns-route1" value="contract_request / _approved / _rejected&#xa;→ /projects/:id/change-requests" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="140" width="580" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ns-route2" value="contract_update&#xa;→ /projects/:id/contract" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="200" width="580" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ns-route3" value="chat_message&#xa;→ /projects/:id/chat" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="260" width="580" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ns-route4" value="new_email&#xa;→ /email-organiser/:projectId" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="320" width="580" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ns-route5" value="deadline_upcoming&#xa;→ /projects/:id/timeline" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="380" width="580" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ns-route6" value="manager_alert / system&#xa;→ /projects/:id  (fallback)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="440" width="580" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ns-click-title" value="&lt;b&gt;Click handler (NotificationFeed)&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="510" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="ns-click-rule" value="&lt;Link href={hrefForNotification(n)} onClick={() =&gt; markRead.mutate(n.id)}&gt;&#xa;→ POST /api/notifications/&lt;pk&gt;/read/&#xa;→ notification.read_by.add(request.user)&#xa;→ row disappears from the clicker&#39;s feed only" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;fontFamily=monospace;align=left;" vertex="1" parent="1">
          <mxGeometry x="920" y="540" width="580" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ns-click-note" value="Navbar bell and the project overview panel both render from the same queryset, so dismissing in one clears it in the other for that user. Other users keep seeing it until they click too." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#fffde7;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="640" width="580" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Multi-Tab Auth" id="multi-tab-auth-2026">
    <mxGraphModel dx="1800" dy="1200" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="mta-title" value="&lt;b&gt;Per-tab auth — two users in one browser&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#666&quot;&gt;sessionStorage + Authorization: Bearer replaced httpOnly cookies so two tabs can hold two independent sessions&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="900" height="50" as="geometry" />
        </mxCell>
        <mxCell id="mta-lane-a" value="Tab A (Manager session)" style="swimlane;startSize=40;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="700" height="320" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-1" value="POST /api/auth/login/&#xa;{ email: alice@…, password: … }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="mta-lane-a">
          <mxGeometry x="30" y="60" width="290" height="50" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-2" value="Response body:&#xa;{ user, access, refresh }&#xa;(no Set-Cookie)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="mta-lane-a">
          <mxGeometry x="360" y="50" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-3" value="tokenStorage.set(access, refresh)&#xa;→ window.sessionStorage on Tab A only" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="mta-lane-a">
          <mxGeometry x="30" y="140" width="290" height="60" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-4" value="Every API call from Tab A:&#xa;Authorization: Bearer &lt;tab-A access&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="mta-lane-a">
          <mxGeometry x="360" y="140" width="290" height="60" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-5" value="WS /ws/chat/:id/?token=&lt;tab-A access&gt;&#xa;ChatConsumer parses query_string&#xa;→ SimpleJWT verify → scope[&quot;user&quot;]" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="mta-lane-a">
          <mxGeometry x="30" y="220" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-6" value="Everything scoped to Manager identity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="mta-lane-a">
          <mxGeometry x="360" y="220" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-a" source="mta-a-1" target="mta-a-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-a" source="mta-a-2" target="mta-a-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-a" source="mta-a-3" target="mta-a-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-a" source="mta-a-4" target="mta-a-5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-a-e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-a" source="mta-a-5" target="mta-a-6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-lane-b" value="Tab B (Account session — same browser, same origin)" style="swimlane;startSize=40;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="760" y="90" width="700" height="320" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-1" value="POST /api/auth/login/&#xa;{ email: bob@…, password: … }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="mta-lane-b">
          <mxGeometry x="30" y="60" width="290" height="50" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-2" value="Response body:&#xa;{ user, access, refresh }&#xa;(no Set-Cookie)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="mta-lane-b">
          <mxGeometry x="360" y="50" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-3" value="tokenStorage.set(access, refresh)&#xa;→ window.sessionStorage on Tab B only&#xa;(Tab A&#39;s sessionStorage is untouched)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="mta-lane-b">
          <mxGeometry x="30" y="140" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-4" value="Every API call from Tab B:&#xa;Authorization: Bearer &lt;tab-B access&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="mta-lane-b">
          <mxGeometry x="360" y="140" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-5" value="On 401 (expired access):&#xa;POST /api/auth/token/refresh/&#xa;body: { refresh: &lt;tab-B refresh&gt; }" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="mta-lane-b">
          <mxGeometry x="30" y="230" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-6" value="Everything scoped to Account identity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="mta-lane-b">
          <mxGeometry x="360" y="230" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-b" source="mta-b-1" target="mta-b-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-b" source="mta-b-2" target="mta-b-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-b" source="mta-b-3" target="mta-b-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-b" source="mta-b-4" target="mta-b-5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-b-e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="mta-lane-b" source="mta-b-5" target="mta-b-6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mta-key-title" value="&lt;b&gt;Why this works&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="mta-key1" value="• sessionStorage is per-tab — Tab A and Tab B each hold their own access/refresh keys (auth.access / auth.refresh).&#xa;• Cookies are per-origin — the old httpOnly-cookie model could only hold ONE token for both tabs, so whichever logged in last overwrote the other.&#xa;• Backend dropped CookieJWTAuthentication; default SimpleJWT JWTAuthentication reads the Authorization header and works equally for both tabs." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=#fffde7;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="1420" height="80" as="geometry" />
        </mxCell>
        <mxCell id="mta-tradeoff-title" value="&lt;b&gt;Trade-off (PLANS.md §5 mitigates)&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="570" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="mta-tradeoff" value="• sessionStorage is JS-readable — an XSS vuln could exfiltrate tokens (httpOnly cookies couldn&#39;t).&#xa;• Mitigations in place: 15-minute access token TTL, refresh rotation + blacklist-after-rotation.&#xa;• Mitigation queued: strict Content-Security-Policy with no &#39;unsafe-inline&#39; for script-src (PLANS.md §5).&#xa;• Closing a tab logs the tab out (sessionStorage clears); re-login required per tab session." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="1420" height="100" as="geometry" />
        </mxCell>
        <mxCell id="mta-ws-title" value="&lt;b&gt;WebSocket chat path&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="mta-ws" value="use-chat.ts appends ?token=&lt;sessionStorage access&gt; to the WS URL. ChatConsumer.connect() parses query_string via urllib.parse.parse_qs, verifies via rest_framework_simplejwt.tokens.AccessToken, and loads the User. The dead _authenticate_from_cookie helper was deleted 2026-04-15." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="750" width="1420" height="70" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
