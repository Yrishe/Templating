        <mxCell id="p3-title" value="&lt;b&gt;Phase 3 — AI-Suggested Reply Pipeline&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#666&quot;&gt;Inbound email + PDF text extraction + Claude (narrowed-knowledge RAG)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;" parent="1" vertex="1">
